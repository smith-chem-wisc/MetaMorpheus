<UserControl x:Class="MetaMorpheusGUI.FragmentReanalysisControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MetaMorpheusGUI"
             xmlns:guiFunctions="clr-namespace:GuiFunctions;assembly=GuiFunctions"
             mc:Ignorable="d" 
             d:DesignHeight="200" d:DesignWidth="800">

    <Grid d:DataContext="{x:Type guiFunctions:FragmentationReanalysisViewModel}" >
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- All options in the header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal">

            <Button x:Name="SearchButton" Content="Search" Width="64" Height="24"
                    HorizontalAlignment="Left"  Margin="5 3" Style="{StaticResource MetaDrawButtonStyle}"
                    VerticalContentAlignment="Center" Click="SearchWithNewIons_OnClick" />

            <CheckBox Content="Persist?" VerticalAlignment="Center"
                      IsChecked="{Binding Persist}"
                      Margin="5 3" ToolTip="Research each identification as they are selected" />

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20 3">
                <TextBlock Text="Set Dissociation Type: " VerticalAlignment="Center" />
                <ComboBox x:Name="DissociationTypeComboBox" ItemsSource="{Binding DissociationTypes}"
                          SelectedItem="{Binding SelectedDissociationType}"
                          Margin="5 3" VerticalContentAlignment="Center" Width="80"
                          HorizontalContentAlignment="Center"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20 3">
                <TextBlock Text="Mass Tolerance (ppm): " VerticalAlignment="Center" />
                <local:DoubleTextBoxControl Text="{Binding ProductIonMassTolerance, FallbackValue=20}"
                                            HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                            VerticalAlignment="Center" VerticalContentAlignment="Center"
                                            BorderThickness="1" Width="60" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="20 3">
                <CheckBox Content="Use internal ions of minimum length " IsChecked="{Binding FragmentationParamsViewModel.GenerateInternalIons}"
                          HorizontalContentAlignment="Right" VerticalAlignment="Center" />
                <local:IntegerTexBoxControl Text="{Binding FragmentationParamsViewModel.MinInternalIonLength, FallbackValue=10}"
                                            HorizontalAlignment="Center" HorizontalContentAlignment="Center"
                                            IsEnabled="{Binding FragmentationParamsViewModel.GenerateInternalIons}"
                                            VerticalAlignment="Center" VerticalContentAlignment="Center"
                                            BorderThickness="1" Width="40" />
            </StackPanel>
        </StackPanel>

        <!-- Fragment ion type display -->
        <ListView Grid.Row="1" Background="{StaticResource BackgroundColor}"
                  ItemsSource="{Binding PossibleProducts}" BorderThickness="0">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <CheckBox IsChecked="{Binding Use}" />
                        <TextBlock Text="{Binding TypeString}"></TextBlock>
                    </StackPanel>
                </DataTemplate>
            </ListView.ItemTemplate>
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <UniformGrid Columns="6"/>
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
        </ListView>

        <!-- M-Ion Settings Toggle Button -->
        <ToggleButton Grid.Row="1"  x:Name="MIonSettingsToggle" Content="M-Ion Settings" 
                      Width="100" Height="20" VerticalAlignment="Bottom" HorizontalAlignment="Right"
                      Background="{StaticResource SecondaryButtonColor}" Foreground="{StaticResource TextColor2}"
                      FontSize="14" Margin="0 0 0 0" BorderThickness="0" FontWeight="SemiBold" ToolTip="Configure M-Ion generation and neutral losses"
                      >
            <ToggleButton.Template>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="border"
                             Background="{TemplateBinding Background}" 
                             CornerRadius="4"
                             SnapsToDevicePixels="True">
                        <TextBlock Text="{TemplateBinding Content}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Foreground="{TemplateBinding Foreground}"
                                   FontSize="{TemplateBinding FontSize}"
                                   FontWeight="{TemplateBinding FontWeight}"
                                   Padding="{TemplateBinding Padding}" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource PurpleAccentColor}" />
                            <Setter Property="Foreground" Value="{StaticResource TextColor1}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </ToggleButton.Template>
        </ToggleButton>

        <!-- M-Ion Settings Popup -->
        <Popup x:Name="MIonSettingsPopup" 
               PlacementTarget="{Binding ElementName=MIonSettingsToggle}"
               Placement="Bottom"
               IsOpen="{Binding ElementName=MIonSettingsToggle, Path=IsChecked}"
               StaysOpen="False"
               AllowsTransparency="True"
               PopupAnimation="Slide">
            <Border Background="{StaticResource BackgroundColor}" 
                    BorderBrush="Gray" BorderThickness="2"
                    Padding="10" CornerRadius="5"
                    Width="600">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.5"/>
                </Border.Effect>
                
                <Grid DataContext="{Binding FragmentationParamsViewModel}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- M-Ion Generation Options -->
                    <StackPanel Grid.Row="0" Orientation="Vertical" Margin="0,0,0,10">
                        <CheckBox Content="Generate M-Ions" IsChecked="{Binding GenerateMIon}" 
                                  VerticalAlignment="Center" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <CheckBox Content="Mods Can Suppress Base Loss" 
                                  IsChecked="{Binding ModsCanSuppressBaseLossFragments}" 
                                  VerticalAlignment="Center" Margin="0,0,0,0"
                                  Visibility="{Binding Source={x:Static guiFunctions:GuiGlobalParamsViewModel.Instance}, Path=IsRnaMode, Converter={StaticResource bool2VisConverter}}"/>
                    </StackPanel>

                    <!-- M-Ion Losses -->
                    <GroupBox Grid.Row="1" Header="M-Ion Neutral Losses" Padding="5">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Selection Buttons -->
                            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,5">
                                <Button Content="Select All" Command="{Binding AddAllLossesCommand}" 
                                        Width="70" Height="22" Margin="2"
                                        Style="{StaticResource MetaDrawButtonStyle}"/>
                                <Button Content="Clear All" Command="{Binding RemoveAllLossesCommand}" 
                                        Width="70" Height="22" Margin="2"
                                        Style="{StaticResource MetaDrawButtonStyle}"/>
                            </StackPanel>

                            <!-- Losses List in UniformGrid -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                <ItemsControl ItemsSource="{Binding AvailableMIonLosses}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="2"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}" Margin="3">
                                                <CheckBox.Content>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Name}" />
                                                        <TextBlock Text=" (" Margin="2,0,0,0"/>
                                                        <TextBlock Text="{Binding Annotation}"/>
                                                        <TextBlock Text=")"/>
                                                    </StackPanel>
                                                </CheckBox.Content>
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </GroupBox>
                </Grid>
            </Border>
        </Popup>
    </Grid>
</UserControl>
