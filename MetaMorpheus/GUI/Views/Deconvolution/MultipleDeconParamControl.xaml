<UserControl x:Class="MetaMorpheusGUI.MultipleDeconParamControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MetaMorpheusGUI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <local:DeconvolutionTypeToControlConverter x:Key="DeconTypeToControlConverter"/>

        <Style x:Key="CircleRemoveButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
            <Setter Property="Content" Value="X"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Ellipse Fill="Red" Width="18" Height="18"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Content="{TemplateBinding Content}"
                                              TextElement.Foreground="White"
                                              TextElement.FontSize="11"
                                              TextElement.FontWeight="Bold"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SubParamGroupBoxStyle" TargetType="GroupBox">
            <Setter Property="Margin" Value="0 0 0 10"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource CircleRemoveButtonStyle}"
                                    Click="RemoveSubType_Click" Tag="{Binding}" />
                            <TextBlock Text="{Binding}" VerticalAlignment="Center" FontWeight="Bold" Margin="5 0 0 0" />
                        </StackPanel>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <GroupBox Header="Shared Parameters" Margin="0 0 0 10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Max Assumed Charge State:" Grid.Column="0" Grid.Row="0" />
                    <local:IntegerTexBoxControl Grid.Column="1" Grid.Row="0" Width="45"
                                                Text="{Binding SharedMaxAssumedChargeState}"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" AllowNegative="True">
                        <TextBox.ToolTip>
                            <TextBlock>
                                Shared maximum charge state applied to all sub-deconvolution types.
                            </TextBlock>
                        </TextBox.ToolTip>
                    </local:IntegerTexBoxControl>

                    <Label Content="Min Assumed Charge State:" Grid.Column="2" Grid.Row="0" />
                    <local:IntegerTexBoxControl Grid.Column="3" Grid.Row="0" Width="45"
                                                Text="{Binding SharedMinAssumedChargeState}"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" AllowNegative="True">
                        <TextBox.ToolTip>
                            <TextBlock>
                                Shared minimum charge state applied to all sub-deconvolution types.
                            </TextBlock>
                        </TextBox.ToolTip>
                    </local:IntegerTexBoxControl>
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 0 0 10">
                <ComboBox ItemsSource="{Binding AvailableSubTypes}"
                          SelectedItem="{Binding SelectedAddType}"
                          Width="150" Height="25" />
                <Button Content="Add Deconvolution Type" Height="25" Margin="10 0 0 0"
                        Click="AddSubType_Click" />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding SubParameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <GroupBox Header="{Binding}" Style="{StaticResource SubParamGroupBoxStyle}">
                            <ContentControl Content="{Binding Converter={StaticResource DeconTypeToControlConverter}}" />
                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
