<UserControl x:Class="MetaMorpheusGUI.MultipleDeconParamControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MetaMorpheusGUI"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <local:DeconvolutionTypeToControlConverter x:Key="DeconTypeToControlConverter"/>
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="10">
            <GroupBox Header="Shared Parameters" Margin="0 0 0 10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Content="Max Assumed Charge State:" Grid.Column="0" Grid.Row="0" />
                    <local:IntegerTexBoxControl Grid.Column="1" Grid.Row="0" Width="45"
                                                Text="{Binding SharedMaxAssumedChargeState}"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" AllowNegative="True">
                        <TextBox.ToolTip>
                            <TextBlock>
                                Shared maximum charge state applied to all sub-deconvolution types.
                            </TextBlock>
                        </TextBox.ToolTip>
                    </local:IntegerTexBoxControl>

                    <Label Content="Min Assumed Charge State:" Grid.Column="2" Grid.Row="0" />
                    <local:IntegerTexBoxControl Grid.Column="3" Grid.Row="0" Width="45"
                                                Text="{Binding SharedMinAssumedChargeState}"
                                                HorizontalContentAlignment="Center" VerticalContentAlignment="Center" AllowNegative="True">
                        <TextBox.ToolTip>
                            <TextBlock>
                                Shared minimum charge state applied to all sub-deconvolution types.
                            </TextBlock>
                        </TextBox.ToolTip>
                    </local:IntegerTexBoxControl>

                    <Label Content="Polarity:" Grid.Column="0" Grid.Row="1" />
                    <ComboBox Grid.Column="1" Grid.Row="1" Width="100" Height="25"
                              ItemsSource="{Binding Polarities}"
                              SelectedItem="{Binding SharedPolarity}" />
                </Grid>
            </GroupBox>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0 0 0 10">
                <ComboBox ItemsSource="{Binding AvailableSubTypes}"
                          SelectedItem="{Binding SelectedAddType}"
                          Width="150" Height="25" />
                <Button Content="Add Deconvolution Type" Height="25" Margin="10 0 0 0"
                        Click="AddSubType_Click" />
            </StackPanel>

            <ItemsControl ItemsSource="{Binding SubParameters}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <GroupBox Margin="0 0 0 10" Header="{Binding}">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Button Grid.Row="0" Content="X" Width="22" Height="22"
                                        HorizontalAlignment="Right" Margin="0 0 5 5"
                                        Click="RemoveSubType_Click" Tag="{Binding}" />
                                <ContentControl Grid.Row="1" Content="{Binding Converter={StaticResource DeconTypeToControlConverter}}" />
                            </Grid>
                        </GroupBox>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</UserControl>
