<UserControl x:Class="MetaMorpheusGUI.FragmentationParamsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:MetaMorpheusGUI"
             xmlns:guiFunctions="clr-namespace:GuiFunctions;assembly=GuiFunctions"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="600"
             d:DataContext="{x:Static guiFunctions:FragmentationParamsDesignModel.Instance}">

    <UserControl.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderThickness" Value="3 1 1 1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="DarkSlateGray"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="Black" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <GroupBox Header="Fragment Ion Search Parameters">

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,5,5,5">
                    <CheckBox x:Name="AddCompIonCheckBox" Content="Generate Complementary Ions"
                          ToolTipService.ShowDuration="999999" ToolTipService.InitialShowDelay="500"
                          IsChecked="{Binding GenerateComplementaryIons}">
                        <CheckBox.ToolTip>
                            <TextBlock>
                            Generates experimental (not theoretical) complementary ions for each MS2.
                            <LineBreak />
                            Useful for localization of modifications.
                            </TextBlock>
                        </CheckBox.ToolTip>
                    </CheckBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="10,5,5,5">
                    <CheckBox x:Name="NTerminalIons" DockPanel.Dock="Top" ToolTipService.ShowDuration="999999"
                          ToolTipService.InitialShowDelay="500" IsChecked="{Binding RightSideFragmentIons}">
                        <CheckBox.Content>
                            <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                 ConverterParameter="N-Terminal Ions" />
                        </CheckBox.Content>
                        <CheckBox.ToolTip>
                            <TextBlock>
                                <TextBlock.Text>
                                    <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                         ConverterParameter="Search for theoretical ions from the N-Terminus. &#x0a;The specific ion series are specified through the dissociation type." />
                                </TextBlock.Text>
                            </TextBlock>
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <CheckBox x:Name="CTerminalIons" Margin="5,0,0,5" DockPanel.Dock="Top"
                          ToolTipService.ShowDuration="999999" ToolTipService.InitialShowDelay="500"
                          IsChecked="{Binding LeftSideFragmentIons}">
                        <CheckBox.Content>
                            <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                 ConverterParameter="C-Terminal Ions" />
                        </CheckBox.Content>
                        <CheckBox.ToolTip>
                            <TextBlock>
                                <TextBlock.Text>
                                    <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                         ConverterParameter="Search for theoretical ions from the C-Terminus. &#x0a;The specific ion series are specified through the dissociation type." />
                                </TextBlock.Text>
                            </TextBlock>
                        </CheckBox.ToolTip>
                    </CheckBox>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5,0,0,5"
                        Visibility="{Binding  Converter={StaticResource CollapseOnRnaModeConverter}}">
                    <CheckBox x:Name="InternalIonsCheckBox" Content="Internal Ions" Margin="5,0,0,5" DockPanel.Dock="Top"
                          ToolTipService.ShowDuration="999999" IsChecked="{Binding GenerateInternalIons}"
                          ToolTipService.InitialShowDelay="500">
                        <CheckBox.ToolTip>
                            <TextBlock>
                            Search for theoretical internal fragment ions AFTER scoring. These ions are useful for localizing PTMs, but are not used during scoring.
                            </TextBlock>
                        </CheckBox.ToolTip>
                    </CheckBox>
                    <Label x:Name="minInternalFragmentLengthLabel" Content="Min Internal Length:" Margin="18,-6,0,0" />
                    <local:IntegerTexBoxControl x:Name="MinInternalFragmentLengthTextBox" Width="45"
                                            IsEnabled="{Binding IsChecked, ElementName=InternalIonsCheckBox}"
                                            Text="{Binding MinInternalIonLength}"
                                            ToolTipService.ShowDuration="999999" ToolTipService.InitialShowDelay="500">
                        <TextBox.ToolTip>
                            <TextBlock>
                                <TextBlock.Text>
                                    <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                         ConverterParameter="Minimum length (number of amino acids) allowed for an internal fragment ion. &#x0a;Small internal fragments can be uninformative and computationally expensive." />
                                </TextBlock.Text>
                            </TextBlock>
                        </TextBox.ToolTip>
                    </local:IntegerTexBoxControl>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="5">
                    <Label x:Name="maxFragmentSize" Content="Max Fragment Mass (Da):" Width="146" />
                    <local:DoubleTextBoxControl x:Name="MaxFragmentMassTextBox" Width="45"
                                            Text="{Binding MaxFragmentMassDa}" ToolTipService.ShowDuration="999999"
                                            ToolTipService.InitialShowDelay="500">
                        <TextBox.ToolTip>
                            <TextBlock>
                            Indexed Search Only: Limits the maximum MS2 fragment mass to avoid rare crashes.
                            <LineBreak />
                            A very high value (e.g. 30000) does not impact performance.
                            </TextBlock>
                        </TextBox.ToolTip>
                    </local:DoubleTextBoxControl>
                </StackPanel>

            </StackPanel>

            <StackPanel Grid.Column="1">
                <!-- Generate M Ions checkbox -->
                <CheckBox Margin="10,5,5,5"
                          IsChecked="{Binding GenerateMIon}"
                          ToolTipService.ShowDuration="999999"
                          ToolTipService.InitialShowDelay="500">
                    <CheckBox.Content>
                        <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                 ConverterParameter="Generate M Ions" />
                    </CheckBox.Content>
                    <CheckBox.ToolTip>
                        <ToolTip>
                            <ToolTip.Content>
                                <Binding Converter="{StaticResource ProteinRnaTerminologyConverter}"
                                         ConverterParameter="Generate fragment ions with mass losses (M ions). For RNA, this includes base losses, water losses, and phospho losses." />
                            </ToolTip.Content>
                        </ToolTip>
                    </CheckBox.ToolTip>
                </CheckBox>
                
                <!-- RNA-specific options (only visible in RNA mode) -->
                <StackPanel Visibility="{Binding 
				Converter={StaticResource CollapseOnProteinModeConverter}}">

                    <!-- M-Ion Losses Selection -->
                    <Expander Header="M-Ion Loss Selection" Margin="10,5,5,5" IsExpanded="False">
                        <Border BorderBrush="{StaticResource BorderColor}" BorderThickness="1" CornerRadius="5" Padding="5">
                            <ScrollViewer MaxHeight="200" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding AvailableMIonLosses}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <CheckBox Margin="5,2"
                                                      IsChecked="{Binding IsSelected}"
                                                      IsEnabled="{Binding DataContext.GenerateMIon, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      ToolTip="{Binding Annotation}">
                                                <TextBlock Text="{Binding Name}" />
                                            </CheckBox>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Border>
                    </Expander>
                </StackPanel>

                <!-- Note about M-Ion losses for peptides -->
                <TextBlock Margin="10,5,5,5"
                           TextWrapping="Wrap"
                           Foreground="Gray"
                           FontStyle="Italic" Visibility="{Binding 
				Converter={StaticResource CollapseOnProteinModeConverter}}">
                    Note: M-ion losses for peptides include common losses like water (-H2O) and phospho losses (-HPO3).
                </TextBlock>
            </StackPanel>
        

        </Grid>
        
    </GroupBox>
</UserControl>
