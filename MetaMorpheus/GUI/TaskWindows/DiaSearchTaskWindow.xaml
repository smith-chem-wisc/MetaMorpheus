<Window x:Class="MetaMorpheusGUI.DiaSearchTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:MetaMorpheusGUI"
        mc:Ignorable="d"
        KeyDown="KeyPressed"
        Title="DIA Search Task" Width="600" Height="620"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderThickness" Value="3 1 1 1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="DarkSlateGray"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="Black" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="3 0 0 0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="50" />
        </Grid.RowDefinitions>

        <!-- Scrollable parameter area -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <DockPanel>

                <!-- Task name -->
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="5,5,0,0">
                    <Label Content="Task Name:" Width="90"/>
                    <TextBox x:Name="OutputFileNameTextBox" Width="200">
                        <TextBox.Style>
                            <Style TargetType="TextBox" xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                <Style.Resources>
                                    <VisualBrush x:Key="CueBannerBrush" AlignmentX="Left" AlignmentY="Center" Stretch="None">
                                        <VisualBrush.Visual>
                                            <Label Content="DiaSearchTask" Foreground="Gray" Padding="5 0 0 0"/>
                                        </VisualBrush.Visual>
                                    </VisualBrush>
                                </Style.Resources>
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="{x:Static sys:String.Empty}">
                                        <Setter Property="Background" Value="{StaticResource CueBannerBrush}" />
                                    </Trigger>
                                    <Trigger Property="Text" Value="{x:Null}">
                                        <Setter Property="Background" Value="{StaticResource CueBannerBrush}" />
                                    </Trigger>
                                    <Trigger Property="IsKeyboardFocused" Value="True">
                                        <Setter Property="Background" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                </StackPanel>

                <StackPanel DockPanel.Dock="Top" Margin="10">

                    <!-- ── Extraction Parameters ── -->
                    <GroupBox Header="Extraction Parameters" Margin="0,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <!-- Fragment m/z Tolerance -->
                            <Label Grid.Row="0" Grid.Column="0" Content="Fragment m/z Tolerance (ppm):"
                                   VerticalAlignment="Center"
                                   ToolTip="PPM tolerance used when matching fragment ions to library spectra."/>
                            <TextBox x:Name="PpmToleranceTextBox" Grid.Row="0" Grid.Column="1"
                                     Width="80" HorizontalAlignment="Left" VerticalAlignment="Center"
                                     ToolTip="PPM tolerance used when matching fragment ions to library spectra."/>

                            <!-- RT Window -->
                            <Label Grid.Row="1" Grid.Column="0" Content="Initial RT Window (± min):"
                                   VerticalAlignment="Center"
                                   ToolTip="Half-width of the initial RT extraction window in minutes. Adaptive windows are used after calibration converges."/>
                            <TextBox x:Name="RtWindowTextBox" Grid.Row="1" Grid.Column="1"
                                     Width="80" HorizontalAlignment="Left" VerticalAlignment="Center"
                                     ToolTip="Half-width of the initial RT extraction window in minutes."/>

                            <!-- Min Fragments -->
                            <Label Grid.Row="2" Grid.Column="0" Content="Min Fragments Required:"
                                   VerticalAlignment="Center"
                                   ToolTip="Minimum number of detected fragment ions required to report a result."/>
                            <TextBox x:Name="MinFragmentsTextBox" Grid.Row="2" Grid.Column="1"
                                     Width="80" HorizontalAlignment="Left" VerticalAlignment="Center"
                                     ToolTip="Minimum number of detected fragment ions required to report a result."/>
                        </Grid>
                    </GroupBox>

                    <!-- ── Calibration ── -->
                    <GroupBox Header="RT Calibration" Margin="0,5,0,5">
                        <StackPanel>
                            <CheckBox x:Name="UseIrtCalibrationCheckBox" Margin="0,4,0,0"
                                      Content="Use iterative iRT calibration (recommended)"
                                      ToolTip="Iteratively refines the RT extraction window using high-confidence anchor peptides. Substantially increases IDs."/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ── Performance ── -->
                    <GroupBox Header="Performance" Margin="0,5,0,5">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="32"/>
                                <RowDefinition Height="32"/>
                            </Grid.RowDefinitions>

                            <!-- Max Threads -->
                            <Label Grid.Row="0" Grid.Column="0" Content="Max Threads (-1 = all cores):"
                                   VerticalAlignment="Center"
                                   ToolTip="Maximum number of CPU threads to use. -1 uses all available cores."/>
                            <TextBox x:Name="MaxThreadsTextBox" Grid.Row="0" Grid.Column="1"
                                     Width="80" HorizontalAlignment="Left" VerticalAlignment="Center"
                                     ToolTip="Maximum number of CPU threads. -1 = all cores."/>

                            <!-- GPU -->
                            <CheckBox x:Name="PreferGpuCheckBox" Grid.Row="1" Grid.Column="0"
                                      Grid.ColumnSpan="2" Margin="0,4,0,0"
                                      Content="Prefer GPU acceleration (experimental)"
                                      ToolTip="Use GPU for fragment extraction and scoring when a compatible device is detected. Falls back to CPU if unavailable."/>
                        </Grid>
                    </GroupBox>

                    <!-- ── Output ── -->
                    <GroupBox Header="Output" Margin="0,5,0,5">
                        <StackPanel>
                            <CheckBox x:Name="WritePsmTsvCheckBox" Margin="0,4,0,0"
                                      Content="Write .psmtsv results file (MetaDraw compatible)"
                                      ToolTip="Writes AllDiaPSMs.psmtsv in MetaMorpheus standard format, compatible with MetaDraw."/>
                            <CheckBox x:Name="WriteDiagnosticsCheckBox" Margin="0,4,0,0"
                                      Content="Write diagnostic files"
                                      ToolTip="Writes per-file pre-FDR diagnostic TSV files alongside the main results."/>
                            <CheckBox x:Name="WriteDecoyResultsCheckBox" Margin="0,4,0,4"
                                      Content="Include decoy results in output"
                                      ToolTip="When checked, decoy identifications are written alongside targets."/>
                        </StackPanel>
                    </GroupBox>

                    <!-- ── DDA Features (greyed out) ── -->
                    <GroupBox Header="DDA-Only Features (not applicable to DIA)" Margin="0,5,0,5"
                              IsEnabled="False" Opacity="0.45"
                              ToolTip="These options apply to DDA database search and are not used by the DIA engine.">
                        <StackPanel>
                            <CheckBox Content="Search for target peptides" IsChecked="True" Margin="0,4,0,0"/>
                            <CheckBox Content="Search for decoy peptides (target-decoy)" IsChecked="True" Margin="0,4,0,0"/>
                            <CheckBox Content="Non-specific cleavage" Margin="0,4,0,0"/>
                            <CheckBox Content="Semi-specific cleavage" Margin="0,4,0,0"/>
                            <CheckBox Content="Search for glycopeptides" Margin="0,4,0,0"/>
                            <CheckBox Content="Search for crosslinks" Margin="0,4,0,0"/>
                            <CheckBox Content="Classic search (binning)" IsChecked="True" Margin="0,4,0,4"/>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </DockPanel>
        </ScrollViewer>

        <!-- Bottom button row -->
        <Grid Grid.Row="1" Background="White">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="10"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="ErrorTextBox" Grid.Column="0" Foreground="Red"
                       VerticalAlignment="Center" Margin="10,0,0,0" TextWrapping="Wrap"/>
            <Button x:Name="SaveButton" Grid.Column="1" Content="Add the DIA Search Task"
                    Click="SaveButton_Click" Height="34" FontSize="12"
                    Background="#2E8B57" Foreground="White" BorderThickness="0"/>
        </Grid>
    </Grid>
</Window>
