<Window x:Class="MetaMorpheusGUI.CircularSearchTaskWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:guiFunctions="clr-namespace:GuiFunctions;assembly=GuiFunctions"
        mc:Ignorable="d"
        Title="Add Circular Search Task" Width="660" Height="700"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="GroupBox">
            <Setter Property="BorderThickness" Value="3 1 1 1"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="BorderBrush" Value="DarkSlateGray"/>
            <Setter Property="HeaderTemplate">
                <Setter.Value>
                    <DataTemplate>
                        <TextBlock Text="{Binding}" Foreground="Black" FontWeight="Bold"/>
                    </DataTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="3 0 0 0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════ MAIN CONTENT -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <TextBlock Text="Circular Peptide Search Task"
                           FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>

                <!-- ── Fragmentation ──────────────────────────────────────────── -->
                <GroupBox Header="Fragmentation" Margin="0,0,0,8">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Dissociation type:"
                               VerticalAlignment="Center"/>
                        <ComboBox x:Name="DissociationTypeComboBox"
                                  Grid.Row="0" Grid.Column="1"
                                  Width="200" HorizontalAlignment="Left"
                                  VerticalAlignment="Center"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Min internal fragment length:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="MinInternalFragmentLengthTextBox"
                                 Grid.Row="1" Grid.Column="1"
                                 Width="60" HorizontalAlignment="Left"
                                 VerticalAlignment="Center" Text="3"
                                 PreviewTextInput="TextBox_PreviewTextInput_Int"/>
                    </Grid>
                </GroupBox>

                <!-- ── Mass Tolerances ───────────────────────────────────────── -->
                <GroupBox Header="Mass Tolerances" Margin="0,0,0,8">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="80"/>
                            <ColumnDefinition Width="80"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Precursor tolerance:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="PrecursorMassToleranceTextBox"
                                 Grid.Row="0" Grid.Column="1"
                                 VerticalAlignment="Center" Text="10"
                                 PreviewTextInput="TextBox_PreviewTextInput_Double"/>
                        <ComboBox x:Name="PrecursorMassToleranceComboBox"
                                  Grid.Row="0" Grid.Column="2"
                                  VerticalAlignment="Center"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Product tolerance:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="ProductMassToleranceTextBox"
                                 Grid.Row="1" Grid.Column="1"
                                 VerticalAlignment="Center" Text="20"
                                 PreviewTextInput="TextBox_PreviewTextInput_Double"/>
                        <ComboBox x:Name="ProductMassToleranceComboBox"
                                  Grid.Row="1" Grid.Column="2"
                                  VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- ── Mass Difference Acceptor ──────────────────────────────── -->
                <GroupBox Header="Mass Difference Acceptor" Margin="0,0,0,8">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Grid.Column="0" Content="Acceptor type:"
                               VerticalAlignment="Center"/>
                        <ComboBox x:Name="MassDiffAcceptorComboBox"
                                  Grid.Column="1" Width="200"
                                  HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Grid>
                </GroupBox>

                <!-- ── Digestion ─────────────────────────────────────────────── -->
                <GroupBox Header="Digestion" Margin="0,0,0,8">
                    <Grid Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="200"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <Label Grid.Row="0" Grid.Column="0" Content="Protease:"
                               VerticalAlignment="Center"/>
                        <ComboBox x:Name="ProteaseComboBox"
                                  Grid.Row="0" Grid.Column="1"
                                  Width="200" HorizontalAlignment="Left"
                                  VerticalAlignment="Center"/>

                        <Label Grid.Row="1" Grid.Column="0" Content="Max missed cleavages:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="MissedCleavagesTextBox"
                                 Grid.Row="1" Grid.Column="1"
                                 Width="60" HorizontalAlignment="Left"
                                 VerticalAlignment="Center" Text="2"
                                 PreviewTextInput="TextBox_PreviewTextInput_Int"/>

                        <Label Grid.Row="2" Grid.Column="0" Content="Max mods per peptide:"
                               VerticalAlignment="Center"/>
                        <TextBox x:Name="MaxModsTextBox"
                                 Grid.Row="2" Grid.Column="1"
                                 Width="60" HorizontalAlignment="Left"
                                 VerticalAlignment="Center" Text="2"
                                 PreviewTextInput="TextBox_PreviewTextInput_Int"/>
                    </Grid>
                </GroupBox>

                <!-- ── Modifications — two-column grouped TreeViews ──────────── -->
                <GroupBox Header="Modifications" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Fixed mods -->
                        <StackPanel Grid.Column="0" Margin="5,4,5,4">
                            <Label Content="Fixed:"/>
                            <TextBox x:Name="SearchFixedMod"
                                     TextChanged="SearchFixedMod_TextChanged"
                                     Margin="0,0,0,2">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                        <Style.Resources>
                                            <VisualBrush x:Key="CueBannerBrush"
                                                         AlignmentX="Left" AlignmentY="Center"
                                                         Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="Search..." Foreground="Gray"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="{x:Static sys:String.Empty}">
                                                <Setter Property="Background"
                                                        Value="{StaticResource CueBannerBrush}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Null}">
                                                <Setter Property="Background"
                                                        Value="{StaticResource CueBannerBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter Property="Background" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TreeView x:Name="FixedModsTreeView" Height="140"
                                      ItemsSource="{Binding}">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate
                                        DataType="{x:Type guiFunctions:ModTypeForTreeViewModel}"
                                        ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal"
                                                    Background="{Binding Background}">
                                            <CheckBox IsChecked="{Binding Use}"/>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                    <DataTemplate DataType="{x:Type guiFunctions:ModForTreeViewModel}">
                                        <StackPanel Orientation="Horizontal"
                                                    Background="{Binding Background}"
                                                    ToolTip="{Binding ToolTipStuff}">
                                            <CheckBox IsChecked="{Binding Use}"/>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </StackPanel>

                        <!-- Variable mods -->
                        <StackPanel Grid.Column="1" Margin="5,4,5,4">
                            <Label Content="Variable:"/>
                            <TextBox x:Name="SearchVariableMod"
                                     TextChanged="SearchVariableMod_TextChanged"
                                     Margin="0,0,0,2">
                                <TextBox.Style>
                                    <Style TargetType="TextBox"
                                           xmlns:sys="clr-namespace:System;assembly=mscorlib">
                                        <Style.Resources>
                                            <VisualBrush x:Key="CueBannerBrush"
                                                         AlignmentX="Left" AlignmentY="Center"
                                                         Stretch="None">
                                                <VisualBrush.Visual>
                                                    <Label Content="Search..." Foreground="Gray"/>
                                                </VisualBrush.Visual>
                                            </VisualBrush>
                                        </Style.Resources>
                                        <Style.Triggers>
                                            <Trigger Property="Text" Value="{x:Static sys:String.Empty}">
                                                <Setter Property="Background"
                                                        Value="{StaticResource CueBannerBrush}"/>
                                            </Trigger>
                                            <Trigger Property="Text" Value="{x:Null}">
                                                <Setter Property="Background"
                                                        Value="{StaticResource CueBannerBrush}"/>
                                            </Trigger>
                                            <Trigger Property="IsKeyboardFocused" Value="True">
                                                <Setter Property="Background" Value="White"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                            <TreeView x:Name="VariableModsTreeView" Height="140"
                                      ItemsSource="{Binding}">
                                <TreeView.Resources>
                                    <HierarchicalDataTemplate
                                        DataType="{x:Type guiFunctions:ModTypeForTreeViewModel}"
                                        ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal"
                                                    Background="{Binding Background}">
                                            <CheckBox IsChecked="{Binding Use}"/>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                    <DataTemplate DataType="{x:Type guiFunctions:ModForTreeViewModel}">
                                        <StackPanel Orientation="Horizontal"
                                                    Background="{Binding Background}"
                                                    ToolTip="{Binding ToolTipStuff}">
                                            <CheckBox IsChecked="{Binding Use}"/>
                                            <TextBlock Text="{Binding DisplayName}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </TreeView.Resources>
                            </TreeView>
                        </StackPanel>
                    </Grid>
                </GroupBox>

                <!-- ── Output ─────────────────────────────────────────────────── -->
                <GroupBox Header="Output" Margin="0,0,0,8">
                    <Grid Margin="4">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="28"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="24"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>

                        <CheckBox x:Name="WriteDecoyCheckBox"
                                  Grid.Row="0" Grid.Column="0"
                                  Content="Write decoy PSMs"
                                  VerticalAlignment="Center"/>
                        <CheckBox x:Name="WriteContaminantCheckBox"
                                  Grid.Row="1" Grid.Column="0"
                                  Content="Write contaminant PSMs"
                                  VerticalAlignment="Center"/>
                        <CheckBox x:Name="WriteHighQValueCheckBox"
                                  Grid.Row="2" Grid.Column="0"
                                  Content="Write all PSMs (including above q-value threshold)"
                                  VerticalAlignment="Center"/>

                        <!-- Minimum score -->
                        <StackPanel Grid.Row="3" Grid.Column="0"
                                    Orientation="Horizontal" VerticalAlignment="Center">
                            <Label Content="Minimum score allowed:" VerticalAlignment="Center"/>
                            <TextBox x:Name="MinScoreTextBox"
                                     Width="60" VerticalAlignment="Center"
                                     Text="1"
                                     PreviewTextInput="TextBox_PreviewTextInput_Double"/>
                        </StackPanel>

                        <!-- Decoy note -->
                        <TextBlock Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Note: circular decoys always use random shuffling (never reverse)."
                                   Foreground="Gray" FontStyle="Italic"
                                   VerticalAlignment="Center" Margin="4,0,0,0"/>
                    </Grid>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- ═══════════════════════════════════════════════════ ADD / CANCEL ROW -->
        <Grid Grid.Row="1" Margin="10,4,10,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" x:Name="AddTaskButton"
                    Content="Add Task"
                    Click="AddTaskButton_Click"
                    Background="#2e7bcf" Foreground="White"
                    FontWeight="SemiBold" Height="32" Margin="0,0,8,0"/>
            <Button Grid.Column="2" x:Name="CancelButton"
                    Content="Cancel"
                    Click="CancelButton_Click"
                    Background="#666" Foreground="White"
                    Height="32"/>
        </Grid>
    </Grid>
</Window>
